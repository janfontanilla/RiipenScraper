# Riipen login credentials
RIIPEN_EMAIL=you@example.com
RIIPEN_PASSWORD=your-riipen-password

# The URL of your experience / project listing page on Riipen.
# Note: Riipen uses white-labeled subdomains (yours is futurepath.riipen.com).
# The tracking query string (?_gl=...) is optional — it's stripped internally.
RIIPEN_EXPERIENCE_URL=https://futurepath.riipen.com/experiences/vO1X9bVE

# SMTP sender (any STARTTLS provider). Defaults to Gmail because Outlook
# personal accounts have disabled basic-auth SMTP. For Gmail, turn on 2-Step
# Verification then create an App Password and paste it as SMTP_PASSWORD.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Where alerts are delivered
ALERT_EMAIL=you@example.com
